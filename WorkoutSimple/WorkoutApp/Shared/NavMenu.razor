@using System.Text.Json
@inject IJSRuntime JSRuntime

@if (!isLoading)
{
    @if (isAuthenticated)
    {
        <div class="top-row ps-3 navbar navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="">WorkoutApp</a>
            </div>
        </div>

        <div class="nav-scrollable">
            <nav class="flex-column">
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All" style="color: white !important;">
                        <span class="oi oi-home" aria-hidden="true"></span> Главная
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="profile" style="color: white !important;">
                        <span class="oi oi-person" aria-hidden="true"></span> Профиль
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin" style="color: white !important;">
                        <span class="oi oi-shield" aria-hidden="true"></span> Админ-панель
                    </NavLink>
                </div>
            </nav>
        </div>
    }
    else
    {
        // Для неавторизованных не показываем меню вообще
        <div style="display: none;"></div>
    }
}

@code {
    private bool isAuthenticated = false;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await CheckAuth();
        isLoading = false;
    }

    private async Task CheckAuth()
    {
        try
        {
            var savedUserJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "currentUser");
            isAuthenticated = !string.IsNullOrEmpty(savedUserJson);
        }
        catch
        {
            isAuthenticated = false;
        }
    }
}