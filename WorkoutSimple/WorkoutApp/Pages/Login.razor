@page "/login"
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<h3>Вход в систему</h3>

<div class="mb-3">
    <label>Email:</label>
    <input @bind="email" class="form-control" />
</div>
<div class="mb-3">
    <label>Пароль:</label>
    <input type="password" @bind="password" class="form-control" />
</div>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}

<button class="btn btn-primary" @onclick="HandleLogin" disabled="@isLoading">
    @if (isLoading)
    {
        <span>Вход...</span>
    }
    else
    {
        <span>Войти</span>
    }
</button>
<a href="/register" class="btn btn-link">Нет аккаунта?</a>

@code {
    private string email = "";
    private string password = "";
    private string? error;
    private bool isLoading = false;

    private async Task HandleLogin()
    {
        if (isLoading) return;
        
        isLoading = true;
        error = null;

        try
        {
            var loginData = new
            {
                email = email,
                password = password
            };

            var response = await Http.PostAsJsonAsync("http://localhost:5097/api/auth/login", loginData);
            var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
            
            if (response.IsSuccessStatusCode)
            {
                if (result?.user != null)
                {
                    var userJson = JsonSerializer.Serialize(result.user);
                    await JSRuntime.InvokeVoidAsync("localStorage.setItem", "currentUser", userJson);
                    
                    // Принудительно обновляем состояние навигации
                    Navigation.NavigateTo("/", true);
                }
            }
            else
            {
                error = result?.message ?? "Ошибка входа";
            }
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    class LoginResponse
    {
        public string message { get; set; } = "";
        public UserInfo? user { get; set; }
    }

    class UserInfo
    {
        public int Id { get; set; }
        public string Email { get; set; } = "";
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string RegistrationDate { get; set; } = "";
    }
}